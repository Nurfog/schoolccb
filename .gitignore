# Compilados y dependencias de Rust
/target/
**/*.rs.bk
**.rlib
**.rmeta
Cargo.lock (opcional - decidir si lo incluyes o no en git)

# Archivos de entorno y secretos
.env
.env.local
.env.production
.env.development
**.env.*
!.env.example

# Archivos generados por compilación
build/
dist/
*.exe
*.so
*.dll

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.lerna.json
*.tgz

# Logs
*.log
logs/
npm-debug.log
yarn-debug.log
yarn-error.log

# Archivos de sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDE y editores
.idea/
.vscode/settings.json (solo si quieres guardar configuraciones específicas)
*.swp
*.swo
*~
.project
.classpath
.settings/
.metadata/

# Caché de Docker
.docker/
**.dockerignore
compose.override.*

# Archivos temporales y cache
*.tmp
*.temp
.cache/
.temp/
.npm/
.pnpm-store/

# Bundles y assets generados
public/bundle.*
public/assets/*.js
public/assets/*.css

# Pruebas
coverage/
.nyc_output/
__tests__/results.json
test-results/

# Docker-specific (no subir a git)
docker-compose.override.yml
.dockerignore

# Database dumps locales (si los hay)
*.sql.backup
db.backup.*

# Archivos de build de herramientas de empaquetado
.eslintcache
.stylelintcache

# Variables de entorno sensibles - SOLO EN PRODUCCIÓN
secrets/

# Archivos de auditoría o monitoreo
audit-logs/
monitoring/

# Archivos grandes que no deberían estar en git
*.tar.gz
*.zip
*.rar