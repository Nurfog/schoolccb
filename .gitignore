# =========================================
# Rust
# =========================================
# Carpeta de compilación de Rust (donde sea que aparezca en el monorepo)
**/target/

# Archivos de backup de Rust
**/*.rs.bk
**/*.rlib
**/*.rmeta

# Cargo.lock solo se mantiene en binarios/apps finales, no en librerías.
# Este proyecto es una app, así que podría incluirse, pero se omitirá aquí:
rust/Cargo.lock

# =========================================
# Archivos de entorno y secretos
# =========================================
.env
.env.local
.env.development
.env.production
.env.staging
!.env.example

# =========================================
# Node.js / Frontend
# =========================================
node_modules/
**/node_modules/

# Build outputs
dist/
build/
**/dist/
**/build/

# Logs de npm/yarn/pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Cache de herramientas frontend
.npm/
.eslintcache
.stylelintcache
.parcel-cache/
.vite/

# =========================================
# Logs
# =========================================
*.log
logs/
server.log

# =========================================
# Sistema Operativo
# =========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# =========================================
# IDEs y editores
# =========================================
.idea/
.vscode/settings.json
.vscode/*.code-snippets
*.swp
*.swo
*~
.project
.classpath
.settings/
.metadata/

# =========================================
# Docker
# =========================================
docker-compose.override.yml
compose.override.*

# =========================================
# Archivos temporales y caché
# =========================================
*.tmp
*.temp
.cache/
.temp/

# =========================================
# Archivos generados o de pruebas
# =========================================
coverage/
.nyc_output/
test-results/
__tests__/results.json

# =========================================
# Backups y dumps de base de datos
# =========================================
*.sql.backup
db.backup.*
*.bak

# =========================================
# Archivos grandes / binarios comprimidos
# =========================================
*.tar.gz
*.zip
*.rar
*.7z

# =========================================
# Carpetas huérfanas / artefactos locales
# =========================================
# Carpeta src/ raíz fue creada por error durante el desarrollo
src/backend/

# Carpeta debug (typo en gitignore original)
debug/

# Archivos de secretos / monitoreo
secrets/
audit-logs/
monitoring/

# Archivos ejecutables compilados
*.exe
*.so
*.dll