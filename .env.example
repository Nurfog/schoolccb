# ============================================
# SISTEMA DE ADMINISTRACIÓN DE COLEGIOS
# Configuración de Variables de Entorno
# ============================================
# Copiar este archivo a .env y ajustar los valores
# ============================================

# --- PostgreSQL (Base de Datos) ---
DB_USERNAME=postgres
DB_PASSWORD=changeme123!
DB_NAME=colleges
DB_HOST=localhost
DB_PORT=5432

# --- Database Pool Configuration (Optimizado) ---
# Máximo de conexiones simultáneas
DATABASE_MAX_CONNECTIONS=20
# Mínimo de conexiones mantenidas
DATABASE_MIN_CONNECTIONS=5
# Tiempo máximo para adquirir una conexión (segundos)
DATABASE_ACQUIRE_TIMEOUT=30
# Tiempo de inactividad antes de cerrar una conexión (segundos)
DATABASE_IDLE_TIMEOUT=600
# Tiempo máximo de vida de una conexión (segundos)
DATABASE_MAX_LIFETIME=1800

# --- Rust Backend ---
RUST_VERSION=1.77.0
RUST_BACKTRACE=1
RUST_LOG=info,sqlx=warn,actix_web=info
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0

# --- API Configuración ---
API_VERSION=v1
API_PREFIX=/api

# --- JWT (Autenticación) ---
# IMPORTANTE: Generar un secreto seguro de al menos 32 caracteres
# Ejecutar: openssl rand -base64 64 | tr -d '\n' && echo ""
JWT_SECRET_KEY=generate_secure_random_key_here_2024_minimum_32_chars
JWT_EXPIRES_IN=72h

# --- CORS (Cross-Origin Resource Sharing) ---
# Lista de orígenes permitidos (separados por coma)
# En producción, especificar dominios específicos, NO usar "*"
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Node.js Frontend ---
NODE_ENV=production
NODE_PORT=3000
FRONTEND_HOST=localhost
FRONTEND_PORT=8081

# --- Redis (Opcional, para caching) ---
# Para habilitar Redis, usar: docker compose --profile with-redis up
REDIS_URL=redis://redis:6379

# --- Stripe (Pagos) ---
# Opcional: Dejar vacío para usar modo simulado
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC_MONTHLY=price_...
STRIPE_PRICE_ID_BASIC_YEARLY=price_...
STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_ID_PREMIUM_YEARLY=price_...
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ID_ENTERPRISE_YEARLY=price_...

# --- Email / SMTP (Notificaciones) ---
# Configurar para envío de emails (boletines, recordatorios, etc.)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=SchoolCCB
SMTP_FROM_EMAIL=noreply@tudominio.com

# --- Email Queue Configuration ---
# Cola de emails con Redis para envío asíncrono
EMAIL_QUEUE_NAME=email_queue
EMAIL_MAX_RETRIES=3

# --- IA/ML Configuration (Ollama + Whisper) ---
OLLAMA_URL=http://t-800.norteamericano.cl:11434
WHISPER_URL=http://t-800.norteamericano.cl:9000
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=llama3.1

# --- Sistema Base (Contenedor Principal) ---
CONTAINER_NAME=school-admin-main
MAIN_CONTAINER_PORT=3000
ENABLE_PREMIUM_FEATURES=false
SAAS_MODE=false
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@db:5432/${DB_NAME}

# --- Funcionalidades Premium (SaaS) ---
PREMIUM_API_ENDPOINT=https://premium-api.school-admin.com
SAAS_SUBSCRIPTION_KEY=your_saas_key_here
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# --- Optimizaciones y Seguridad ---
MAX_CONNECTION_POOL_SIZE=20
LOG_LEVEL=info
TRUST_PROXY=true
ALLOWED_NETWORK_IPS=127.0.0.1/32

# --- SSL y Certbot ---
DOMAIN_NAME=school-ccb.xyz
CERTBOT_EMAIL=admin@school-ccb.xyz
SSL_ENABLED=false
SSL_CERT_PATH=/etc/letsencrypt/live/school-ccb.xyz/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/school-ccb.xyz/privkey.pem

# --- Autenticación y Sesiones ---
SESSION_SECRET=session_secret_key_secure_2024_minimum_32_chars
TOKEN_REFRESH_INTERVAL=1d
LOGIN_TIMEOUT=15m

# --- Validación de Contraseñas ---
# Requisitos mínimos:
# - 8 caracteres mínimo
# - 1 mayúscula
# - 1 minúscula
# - 1 número
# - 1 carácter especial
PASSWORD_MIN_LENGTH=8
PASSWORD_COMPLEXITY=true

# --- Logging ---
LOG_FILE_PATH=/var/log/school-admin/
LOG_MAX_SIZE=100M
LOG_MAX_FILES=3

# --- Despliegue y Distribución ---
DISTRIBUTOR_NAME="Tu Empresa de Software"
RUST_ENVIRONMENT=development

# --- Configuración de Docker ---
DOCKER_COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=school-admin
CONTAINER_RESTART_POLICY=always

# --- Variables para Rust (2021 Edition) ---
CARGO_HOME=/usr/local/cargo
RUSTUP_HOME=/usr/local/rustup
CARGO_VERSION_OVERRIDE=1.77.0
FEATURE_FLAGS=all

# --- Configuración de Puertos del Sistema ---
SYSTEM_BASE_PORT=8082
API_BACKEND_PORT=8080
FRONTEND_SERVER_PORT=8081
DATABASE_CONNECTION_MAX_IDLE=5
DATABASE_CONNECTION_MAX_LIFETIME=30s

# ============================================
# NOTAS DE SEGURIDAD
# ============================================
# 1. JWT_SECRET_KEY y SESSION_SECRET deben ser únicos y seguros
#    Generar con: openssl rand -base64 64 | tr -d '\n' && echo ""
#
# 2. DB_PASSWORD debe ser complejo y único
#    Generar con: openssl rand -base64 48 | tr -d '\n' && echo ""
#
# 3. En producción, nunca usar valores por defecto
#
# 4. CORS_ORIGINS debe especificar dominios específicos, no "*"
#
# 5. Revisar regularmente los logs de auditoría
# ============================================
