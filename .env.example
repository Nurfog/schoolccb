# ============================================
# SISTEMA DE ADMINISTRACIÓN DE COLEGIOS
# Configuración de Variables de Entorno
# ============================================

# --- PostgreSQL (Base de Datos) ---
DB_USERNAME=postgres
DB_PASSWORD=changeme123!
DB_NAME=colleges
DB_HOST=localhost
DB_PORT=5432

# --- Database Pool Configuration ---
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5
DATABASE_ACQUIRE_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=600
DATABASE_MAX_LIFETIME=1800

# --- Rust Backend ---
RUST_VERSION=1.77.0
RUST_BACKTRACE=1
RUST_LOG=info
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0

# --- API Configuración ---
API_VERSION=v1
API_PREFIX=/api
JWT_SECRET_KEY=generate_secure_random_key_here_2024
JWT_EXPIRES_IN=72h
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Node.js Frontend ---
NODE_ENV=production
NODE_PORT=3000
FRONTEND_HOST=localhost
FRONTEND_PORT=8081

# --- Redis (Opcional, para caching) ---
# Para habilitar Redis, usa: docker compose --profile with-redis up
REDIS_URL=redis://redis:6379

# --- Sistema Base (Contenedor Principal) ---
CONTAINER_NAME=school-admin-main
MAIN_CONTAINER_PORT=3000
ENABLE_PREMIUM_FEATURES=false
SAAS_MODE=false
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@db:5432/${DB_NAME}

# --- Funcionalidades Premium (SaaS) ---
PREMIUM_API_ENDPOINT=https://premium-api.school-admin.com
SAAS_SUBSCRIPTION_KEY=your_saas_key_here
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# --- Optimizaciones y Seguridad ---
MAX_CONNECTION_POOL_SIZE=20
LOG_LEVEL=info
TRUST_PROXY=true
ALLOWED_NETWORK_IPS=127.0.0.1/32
SSL_ENABLED=false
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# --- Configuración de Docker ---
DOCKER_COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=school-admin
CONTAINER_RESTART_POLICY=always

# --- Variables para Rust (2021 Edition) ---
CARGO_HOME=/usr/local/cargo
RUSTUP_HOME=/usr/local/rustup
CARGO_VERSION_OVERRIDE=1.77.0
FEATURE_FLAGS=all

# --- Configuración de Puerto del Sistema Base ---
SYSTEM_BASE_PORT=8082
API_BACKEND_PORT=8080
FRONTEND_SERVER_PORT=8081
DATABASE_CONNECTION_MAX_IDLE=5
DATABASE_CONNECTION_MAX_LIFETIME=30s

# --- Autenticación y Sesiones ---
SESSION_SECRET=session_secret_key_secure_2024
TOKEN_REFRESH_INTERVAL=1d
LOGIN_TIMEOUT=15m
PASSWORD_MIN_LENGTH=8
PASSWORD_COMPLEXITY=true

# --- Logging ---
LOG_FILE_PATH=/var/log/school-admin/
LOG_MAX_SIZE=100M
LOG_MAX_FILES=3

# --- Despliegue y Distribución ---
DISTRIBUTOR_NAME="Tu Empresa de Software"
RUST_ENVIRONMENT=development

# --- SSL y Certbot ---
DOMAIN_NAME=school-ccb.xyz
CERTBOT_EMAIL=admin@school-ccb.xyz
